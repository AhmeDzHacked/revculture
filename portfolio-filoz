<script>
// ── LANG SWITCH ──
const PF_T = {
  it:{
    navBack:'I Nostri Fotografi',
    navBook:'Prenota FILOZ →',
    heroEyebrow:'RevCulture — Fotografo',
    heroLoc:'Switzerland — Nationwide',
    photoCountLabel:'Foto nel portfolio',
    heroSpec:'Supercar · Luxury Lifestyle<br/>Location Alpine',
    ftAll:'Tutte',ftSupercar:'Supercar',ftLifestyle:'Lifestyle',ftEvents:'Events',
    filterSuffix:'foto',
    bookBarLoc:'Switzerland — Nazionale',
    bookBarBtn:'Prenota Ora — WhatsApp',
    mmBack:'← I Nostri Fotografi',
  },
  en:{
    navBack:'Our Photographers',
    navBook:'Book FILOZ →',
    heroEyebrow:'RevCulture — Photographer',
    heroLoc:'Switzerland — Nationwide',
    photoCountLabel:'Photos in portfolio',
    heroSpec:'Supercar · Luxury Lifestyle<br/>Alpine Locations',
    ftAll:'All',ftSupercar:'Supercar',ftLifestyle:'Lifestyle',ftEvents:'Events',
    filterSuffix:'photos',
    bookBarLoc:'Switzerland — Nationwide',
    bookBarBtn:'Book Now — WhatsApp',
    mmBack:'← Our Photographers',
  }
};

function setText(id,txt,html=false){const el=document.getElementById(id);if(el){if(html)el.innerHTML=txt;else el.textContent=txt;}}

function setLang(lang){
  const d=PF_T[lang];

  // nav
  setText('nav-back-text',d.navBack);
  setText('nav-book-el',d.navBook);

  // hero
  setText('hero-eyebrow-el',d.heroEyebrow);
  setText('hero-loc-el',d.heroLoc);
  setText('photo-count-label',d.photoCountLabel);
  document.getElementById('hero-spec-el').innerHTML=d.heroSpec;

  // filters
  setText('ft-all',d.ftAll);setText('ft-supercar',d.ftSupercar);
  setText('ft-lifestyle',d.ftLifestyle);setText('ft-events',d.ftEvents);

  // filter count
  const visible=document.querySelectorAll('.m-item:not(.filtered-out)').length;
  document.getElementById('filterCount').textContent=`${visible} ${d.filterSuffix}`;

  // book bar
  setText('book-bar-loc',d.bookBarLoc);
  setText('book-bar-btn-text',d.bookBarBtn);

  // mobile menu back link
  const mmBack=document.getElementById('mm-back-link');
  if(mmBack) mmBack.textContent=d.mmBack;

  // lang button sync
  document.getElementById('btn-it').style.background=lang==='it'?'var(--r)':'transparent';
  document.getElementById('btn-it').style.color=lang==='it'?'var(--w)':'rgba(244,242,239,.5)';
  document.getElementById('btn-en').style.background=lang==='en'?'var(--r)':'transparent';
  document.getElementById('btn-en').style.color=lang==='en'?'var(--w)':'rgba(244,242,239,.5)';

  // page title
  document.documentElement.lang=lang;
  if(lang==='en'){
    document.title='FILOZ — Portfolio | RevCulture Automotive Photography Switzerland';
  } else {
    document.title='FILOZ — Portfolio | RevCulture Fotografia Automotive Svizzera';
  }
}

const isMobile=()=>window.innerWidth<=768;

// CURSOR
const curEl=document.getElementById('cur'),ringEl=document.getElementById('cur-ring');
let mx=0,my=0,rx=0,ry=0;
if(!isMobile()){
  document.addEventListener('mousemove',e=>{mx=e.clientX;my=e.clientY;curEl.style.left=mx+'px';curEl.style.top=my+'px'});
  (function ar(){rx+=(mx-rx)*.1;ry+=(my-ry)*.1;ringEl.style.left=rx+'px';ringEl.style.top=ry+'px';requestAnimationFrame(ar)})();
  document.querySelectorAll('a,button,.m-item').forEach(el=>{
    el.addEventListener('mouseenter',()=>document.body.classList.add('hov'));
    el.addEventListener('mouseleave',()=>document.body.classList.remove('hov'));
  });
}

// NAV SCROLL
const nav=document.getElementById('nav');
window.addEventListener('scroll',()=>nav.classList.toggle('scrolled',scrollY>60));

// HAMBURGER
const hamburger=document.getElementById('hamburger'),mobileMenu=document.getElementById('mobile-menu'),menuOverlay=document.getElementById('menu-overlay');
function openMenu(){hamburger.classList.add('open');mobileMenu.classList.add('open');menuOverlay.classList.add('open');document.body.style.overflow='hidden'}
function closeMenu(){hamburger.classList.remove('open');mobileMenu.classList.remove('open');menuOverlay.classList.remove('open');document.body.style.overflow=''}
hamburger.addEventListener('click',()=>mobileMenu.classList.contains('open')?closeMenu():openMenu());
menuOverlay.addEventListener('click',closeMenu);
mobileMenu.querySelectorAll('a').forEach(a=>a.addEventListener('click',closeMenu));

// SCROLL REVEAL for gallery items
const ro=new IntersectionObserver(entries=>{
  entries.forEach((e,i)=>{
    if(e.isIntersecting){
      setTimeout(()=>e.target.classList.add('on'),i*60);
      ro.unobserve(e.target);
    }
  });
},{threshold:.08});
document.querySelectorAll('.m-item').forEach(el=>ro.observe(el));

// STICKY BOOK BAR — appears after scrolling past hero
const bookBar=document.getElementById('bookBar');
const heroEl=document.querySelector('.page-hero');
const barObserver=new IntersectionObserver(entries=>{
  bookBar.classList.toggle('visible',!entries[0].isIntersecting);
},{threshold:0});
barObserver.observe(heroEl);

// ── LIGHTBOX ──
const lb=document.getElementById('lightbox');
const lbImg=document.getElementById('lb-img');
const lbCounter=document.getElementById('lb-counter');
const lbDots=document.getElementById('lbDots');

let currentItems=[];  // currently visible items (respects filter)
let currentIdx=0;

function buildDots(){
  lbDots.innerHTML='';
  currentItems.forEach((_,i)=>{
    const d=document.createElement('div');
    d.className='lb-dot'+(i===currentIdx?' active':'');
    d.addEventListener('click',()=>goTo(i));
    lbDots.appendChild(d);
  });
}

function updateDots(){
  lbDots.querySelectorAll('.lb-dot').forEach((d,i)=>d.classList.toggle('active',i===currentIdx));
}

function openLightbox(idx){
  currentIdx=idx;
  lbImg.src=currentItems[idx].querySelector('img').src;
  lbImg.alt=currentItems[idx].querySelector('img').alt;
  lbCounter.textContent=`${idx+1} / ${currentItems.length}`;
  buildDots();
  lb.classList.add('open');
  document.body.classList.add('lb-open');
}

function closeLightbox(){
  lb.classList.remove('open');
  document.body.classList.remove('lb-open');
}

function goTo(idx){
  if(idx<0) idx=currentItems.length-1;
  if(idx>=currentItems.length) idx=0;
  currentIdx=idx;
  lbImg.classList.add('switching');
  setTimeout(()=>{
    lbImg.src=currentItems[idx].querySelector('img').src;
    lbImg.alt=currentItems[idx].querySelector('img').alt;
    lbImg.classList.remove('switching');
    lbCounter.textContent=`${idx+1} / ${currentItems.length}`;
    updateDots();
  },200);
}

// click on gallery item
document.getElementById('gallery').addEventListener('click',e=>{
  const item=e.target.closest('.m-item');
  if(!item||item.classList.contains('filtered-out'))return;
  // rebuild current visible items list
  currentItems=Array.from(document.querySelectorAll('.m-item:not(.filtered-out)'));
  const idx=currentItems.indexOf(item);
  if(idx!==-1) openLightbox(idx);
});

document.getElementById('lb-close').addEventListener('click',closeLightbox);
document.getElementById('lb-prev').addEventListener('click',()=>goTo(currentIdx-1));
document.getElementById('lb-next').addEventListener('click',()=>goTo(currentIdx+1));

// keyboard navigation
document.addEventListener('keydown',e=>{
  if(!lb.classList.contains('open'))return;
  if(e.key==='ArrowRight'||e.key==='ArrowDown') goTo(currentIdx+1);
  if(e.key==='ArrowLeft'||e.key==='ArrowUp') goTo(currentIdx-1);
  if(e.key==='Escape') closeLightbox();
});

// click outside image closes lightbox
lb.addEventListener('click',e=>{if(e.target===lb)closeLightbox()});

// ── FILTER TABS ──
const filterCountEl=document.getElementById('filterCount');

function updateFilterCount(){
  const visible=document.querySelectorAll('.m-item:not(.filtered-out)').length;
  const suffix=document.documentElement.lang==='en'?'photos':'foto';
  filterCountEl.textContent=`${visible} ${suffix}`;
}

document.querySelectorAll('.filter-tab').forEach(tab=>{
  tab.addEventListener('click',()=>{
    document.querySelectorAll('.filter-tab').forEach(t=>t.classList.remove('active'));
    tab.classList.add('active');
    const filter=tab.dataset.filter;
    document.querySelectorAll('.m-item').forEach(item=>{
      const match=filter==='all'||item.dataset.cat===filter;
      item.classList.toggle('filtered-out',!match);
    });
    updateFilterCount();
    // rebuild currentItems for lightbox
    currentItems=Array.from(document.querySelectorAll('.m-item:not(.filtered-out)'));
  });
});

// init currentItems
currentItems=Array.from(document.querySelectorAll('.m-item'));
updateFilterCount();

// TILT on images (desktop)
if(!isMobile()){
  document.querySelectorAll('.m-item').forEach(el=>{
    el.addEventListener('mousemove',e=>{
      const r=el.getBoundingClientRect(),x=(e.clientX-r.left)/r.width-.5,y=(e.clientY-r.top)/r.height-.5;
      el.style.transform=`perspective(600px) rotateY(${x*5}deg) rotateX(${-y*5}deg) scale(1.02)`;
    });
    el.addEventListener('mouseleave',()=>{
      el.style.transform='';
      el.style.transition='transform .6s cubic-bezier(.25,.46,.45,.94),opacity .7s';
      setTimeout(()=>el.style.transition='',600);
    });
  });
}
</script>

